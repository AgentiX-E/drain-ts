{
  "name": "@agentix-e/drain-ts",
  "version": "1.0.0",
  "description": "A production-ready TypeScript/Node.js streaming log template miner — 1:1 port of the official Python Drain3 algorithm. Extracts structured templates from unstructured logs in real time using fixed-depth prefix tree clustering with zero runtime dependencies.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./presets": {
      "import": "./dist/presets.mjs",
      "require": "./dist/presets.cjs",
      "types": "./dist/presets.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:benchmark": "vitest run --config vitest.benchmark.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/ 2>/dev/null || echo '[lint] ESLint not configured'",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts' 'benchmark/**/*.ts' 'docs/**/*.md'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts' 'benchmark/**/*.ts' 'docs/**/*.md'",
    "ci": "pnpm build && pnpm typecheck && pnpm lint && pnpm format:check && pnpm test:coverage",
    "ci:local": "pnpm build && pnpm typecheck && pnpm test:coverage",
    "docs:generate": "typedoc --out docs/api src/index.ts",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "drain",
    "drain3",
    "log-parsing",
    "log-template",
    "log-miner",
    "template-mining",
    "log-analysis",
    "observability",
    "typescript",
    "streaming",
    "online-learning",
    "log-clustering",
    "structured-logging",
    "nodejs",
    "zero-dependency"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentiX-E/drain-ts.git"
  },
  "license": "MIT",
  "author": "Lambertyan <lambertyan@agentix-e.dev>",
  "sideEffects": false,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "peerDependencies": {},
  "peerDependenciesMeta": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}